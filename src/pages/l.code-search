   15: const destinationContext = allDestinations.slice(0, 50).map(d =>
   27:         // Check if API Key is valid/present (Mock check logic)
   32:         const chat = model.startChat({
   35:                     role: "user",
   37:                         text: `You are a helpful travel assistant. You have access to a specific list of destinations. Use this information to answer user queries.
